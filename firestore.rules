rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Gordon College Facility Reservation System - Prototype Rules
    
    // Allow public read and write access for all collections to ensure the prototype works 
    // without authentication hurdles during initial development.
    
    match /facilities/{facilityId} {
      allow read, write: if true;
    }
    
    match /bookings/{bookingId} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}