rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user has an admin email
    // Matches emails like 202411452ADMIN@gordoncollege.edu.ph
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email.lower().matches('.*admin.*@gordoncollege\\.edu\\.ph');
    }

    // User profiles: Users can read and write their own profile
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Facilities: All users can browse the list of facilities (Public campus info).
    // Only administrators can add or modify facility details.
    match /facilities/{facilityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bookings: All users can read the schedule to check availability.
    match /bookings/{bookingId} {
      // Allow list and get for all users to see the campus schedule
      allow read: if true;
      
      // Allow creation for any signed-in user
      allow create: if isSignedIn();
      
      // Allow update if the user owns the booking or is an admin
      allow update: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) || 
        isAdmin()
      );
      
      // Only admins can delete records
      allow delete: if isAdmin();
    }
  }
}