
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "student"] }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Facility": {
      "title": "Facility",
      "description": "A bookable campus facility identified by room number.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Room number (e.g. R101)" },
        "name": { "type": "string", "description": "Display name" },
        "capacity": { "type": "number" },
        "equipment": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "purpose": { "type": "string", "description": "Category: Classroom, Theater, PE Hall, Computer Lab" }
      },
      "required": ["id", "name", "capacity", "equipment", "description", "purpose"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A reservation for a facility.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "facilityId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userRole": { "type": "string", "enum": ["admin", "student"] },
        "facilityName": { "type": "string" },
        "date": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "purpose": { "type": "string" },
        "status": { "type": "string", "enum": ["confirmed", "pending", "cancelled"] }
      },
      "required": ["id", "facilityId", "userId", "userName", "userRole", "facilityName", "date", "startTime", "endTime", "purpose", "status"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles."
    },
    "/facilities/{facilityId}": {
      "schema": { "$ref": "#/backend/entities/Facility" },
      "description": "List of campus facilities."
    },
    "/bookings/{bookingId}": {
      "schema": { "$ref": "#/backend/entities/Booking" },
      "description": "Facility reservation records."
    }
  },
  "metadata": {
    "updatedAt": "2024-05-13T17:30:00Z",
    "version": "1.2.0"
  }
}
